# ==========================================
# CRM PRO V4 - Environment Configuration
# ==========================================

# Database
DATABASE_URL=mysql://crm:change_me@127.0.0.1:3306/chin_crm

# Redis (optional, for rate limiting)
REDIS_URL=
# Set to 1 to enforce Redis as mandatory in production
REQUIRE_REDIS_IN_PROD=0

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000
TRUST_PROXY=0
LOG_LEVEL=info

# Bootstrap (first superadmin, created on fresh DB)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_me_in_production
BOOTSTRAP_TENANT_ID=1

# Migrations
RUN_MIGRATIONS=1

# Security Keys (Generate new ones for production!)
JWT_SECRET=
DATA_ENCRYPTION_KEY=
COOKIE_SECRET=
SESSION_INACTIVITY_MS=86400000
# Optional cookie policy overrides
COOKIE_SAMESITE=lax
COOKIE_SECURE=1
COOKIE_DOMAIN=

# OAuth Configuration
VITE_OAUTH_PORTAL_URL=http://localhost:3000
VITE_APP_ID=chin-crm
OAUTH_SERVER_URL=http://localhost:3000

# Development Mode
VITE_DEV_BYPASS_AUTH=1
ALLOW_DEV_LOGIN=1
ENABLE_DEV_BYPASS=0

# Owner Account (for dev mode)
OWNER_OPEN_ID=dev@localhost
OWNER_EMAIL=dev@localhost

# WhatsApp Configuration
WHATSAPP_WEBHOOK_VERIFY_TOKEN=imagine_crm_verify_2024_secure_token
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v19.0
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Stripe (optional, for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Email SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@crmpro.com

# S3 Storage (optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Sentry (optional, for error tracking)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Forge / Built-in AI (optional)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Mock DB for demos (optional)
ALLOW_MOCK_DB=0

# Webhook allowlist (optional, comma-separated origins)
INTEGRATIONS_WEBHOOK_ALLOWLIST=

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
